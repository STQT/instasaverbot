# Telegram Bot Token (от @BotFather)
BOT_TOKEN=your_bot_token_here

# ─── Instagram авторизация через Playwright ───────────────────
# Бот сам залогинится и обновит куки — ручной экспорт НЕ нужен
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Путь к файлу куки (генерируется автоматически Playwright-ом)
COOKIES_FILE=cookies.txt

# ─── Режим запуска ───────────────────────────────────────────
# "polling" — для локальной разработки (по умолчанию)
# "webhook" — для продакшена на сервере с HTTPS
MODE=polling

# ─── Webhook настройки (нужны только при MODE=webhook) ───────
# Публичный HTTPS URL сервера (без слеша в конце)
# Например: https://yourdomain.com или https://abc123.ngrok-free.app
WEBHOOK_URL=https://yourdomain.com

# Порт для входящих запросов от Telegram (8443, 443, 80 или 88)
WEBHOOK_PORT=8443

# IP для прослушивания (0.0.0.0 = все интерфейсы)
WEBHOOK_LISTEN=0.0.0.0

# Секретный токен для проверки подлинности запросов от Telegram
# Если не задан — генерируется автоматически при каждом запуске
WEBHOOK_SECRET=your_random_secret_here
